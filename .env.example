# =============================================
# SocialAI — Variables de entorno
# Copia este archivo como .env.local
# =============================================

# --- GROQ API (generación de copy) ---
# Obtén tu key en: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# --- SUPABASE ---
# Crea tu proyecto en: https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- UNSPLASH (generación de imágenes) ---
# Registrá tu app en: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- FAL.AI (generación de videos con Kling AI) ---
# Obtén tu key en: https://fal.ai
FAL_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- META / FACEBOOK ---
# Creá tu app en: https://developers.facebook.com
FACEBOOK_APP_ID=0000000000000000
FACEBOOK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- MERCADO PAGO ---
# Panel: https://www.mercadopago.com.uy/developers/panel/app
NEXT_PUBLIC_MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000
MP_APP_ID=0000000000000000
MP_PLAN_BASIC_ID=2c938084xxxxxxxxxxxxxxxxxxxxxxxx
MP_PLAN_PRO_ID=2c938084yyyyyyyyyyyyyyyyyyyyyyyy
MP_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- APP ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
FREE_TIER_LIMIT=10
